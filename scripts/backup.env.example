# Backblaze B2 バックアップ設定
# このファイルをコピーして /etc/backup.env に置いてください
# git には絶対コミットしないこと！

B2_KEY_ID=your_key_id_here
B2_APPLICATION_KEY=your_application_key_here
B2_BUCKET=hayasys-db-backups

# Dockerプロジェクトのパス（デフォルト: /opt/hayasys）
# COMPOSE_DIR=/opt/hayasys

# PostgreSQL接続情報（docker-compose.ymlと合わせる）
# POSTGRES_USER=app
# POSTGRES_DB=app
